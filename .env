# ==================== OpenAI Configuration ====================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="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"

# Model selection (gpt-4, gpt-4o-mini, gpt-3.5-turbo)
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.05

# Optional: Use different models for different tasks
CLASSIFICATION_MODEL=gpt-4o-mini
SQL_GENERATION_MODEL=gpt-4o-mini
CHART_CONFIG_MODEL=gpt-4o-mini
CHAT_MODEL=gpt-4o-mini

# ==================== Database Configuration ====================
# PostgreSQL connection for conversation checkpoints
# Format: postgresql://user:password@host:port/database?sslmode=disable
DB_URI=postgresql://postgres:Kaustubh%407@localhost:5432/smart_query?sslmode=disable

# Optional: Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==================== AWS Configuration ====================
# AWS IAM credentials (or use IAM role in production)
AWS_ACCESS_KEY_ID=AKIAV6MMJLKYXLJ7CP5W
AWS_SECRET_ACCESS_KEY=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
AWS_REGION=ap-south-1

# AWS Glue database name
GLUE_DATABASE_NAME=products_db_new

# Athena workgroup
ATHENA_WORKGROUP=primary

# S3 location for Athena query results
# Must be in format: s3://bucket-name/path/
ATHENA_OUTPUT_LOCATION=s3://new-smart/athena-results/

# Optional: Athena query settings
ATHENA_QUERY_TIMEOUT=120
ATHENA_MAX_RETRIES=3
ATHENA_MAX_RESULTS=1000

# ==================== LangSmith (Optional) ====================
# Enable tracing for debugging and monitoring
# Get API key from: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY="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"
LANGCHAIN_PROJECT='smart_query_project'

# ==================== Application Settings ====================
# UI Configuration
PAGE_TITLE=Smart Data Query & Visualization
PAGE_ICON=🤖

# Feature Flags
ENABLE_DEBUG_MODE=false
ENABLE_SQL_DISPLAY=true
ENABLE_QUERY_CACHING=false

# Rate Limiting
MAX_QUERIES_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO

# ==================== Development Settings ====================
# Set to 'development' or 'production'
ENVIRONMENT=development
MAX_MESSAGES_PER_CHAT=20  # 10 questions + 10 answers
# ==================== Notes ====================
# 1. Never commit this file with real credentials
# 2. Use AWS IAM roles in production instead of access keys
# 3. Enable SSL for database connections in production
# 4. Rotate credentials regularly
# 5. Use secrets manager for production deployments